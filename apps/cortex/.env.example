# ═══════════════════════════════════════════════════════════════
#  TrustTag Cortex — Environment Variables
# ═══════════════════════════════════════════════════════════════

PORT=3001

# PostgreSQL connection string
# For local dev: spin up with `docker run -p 5432:5432 -e POSTGRES_PASSWORD=trusttag postgres:16`
DATABASE_URL=postgresql://postgres:trusttag@localhost:5432/trusttag_cortex

# CORS: allow the web app origin
CORS_ORIGINS=http://localhost:3000

# Feature flags
PHASH_HAMMING_THRESHOLD=10   # Hamming distance <= this is a "strong" visual match
ATTRIBUTE_WEIGHT=0.4          # weight of attribute overlap in final score (rest = pHash similarity)
PHASH_WEIGHT=0.6

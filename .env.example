# ═══════════════════════════════════════════════════════════════════
#  TrustTag Protocol — Environment Template
#  Copy this file to .env (gitignored) and fill in real values.
#  All NEXT_PUBLIC_* values are mirrored from networks.config.ts.
# ═══════════════════════════════════════════════════════════════════

# ── Target Network (Base Sepolia) ───────────────────────────────────
# Source of truth: packages/contracts/networks.config.ts → NETWORKS.baseSepolia
NEXT_PUBLIC_NETWORK_NAME="Base Sepolia"
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_EXPLORER_URL=https://sepolia.basescan.org

# Override with a private Alchemy/Infura endpoint for higher rate limits:
# BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/<YOUR_KEY>

# ── Deployer wallet (contracts workspace only — never exposed to browser) ──
# Required for: npm run deploy:basesepolia
PRIVATE_KEY=

# ── Block Explorer Verification ─────────────────────────────────────
# Obtain a free API key at https://basescan.org/myapikey
# Used by: npx hardhat verify --network baseSepolia <address>
BASESCAN_API_KEY=

# ── Deployed Contract Addresses (fill after running deploy script) ──
# Output by: npm run contracts:deploy:basesepolia
NEXT_PUBLIC_LOST_FOUND_SBT_ADDRESS=
NEXT_PUBLIC_LOST_FOUND_ESCROW_ADDRESS=
NEXT_PUBLIC_POCT_ADDRESS=

# ── Decentralized Storage ───────────────────────────────────────────
NEXT_PUBLIC_IPFS_GATEWAY=https://ipfs.io/ipfs/

# ── Test ETH Faucet ─────────────────────────────────────────────────
# Base Sepolia faucet (requires Coinbase account):
#   https://portal.cdp.coinbase.com/products/faucet
# Alchemy faucet (requires Alchemy account):
#   https://www.alchemy.com/faucets/base-sepolia
